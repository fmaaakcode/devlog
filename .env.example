# DevLog environment variables
#
# Copy this file to ".env" and fill in the values you need.
# All variables are OPTIONAL — DevLog runs with defaults if .env is absent.

# Library scanning is native (queries npm/crates.io/PyPI/Go/Packagist directly)
# — no Vuln API service or key to configure anymore.

# Path to a local clone of Vuln Watch (https://github.com/fmaaakcode/vuln).
# When set, the dashboard's "update available" badge can compare your local
# Vuln Watch version (from its package.json) to the latest GitHub release.
# Optional — the badge still shows the upstream latest if this is unset, it
# just won't tell you whether you're behind.
#
# VULN_LOCAL_PATH=D:/vuln

# Disable all outbound GitHub API calls for the version-check feature
# (the small 🔄 badge in the topbar). Set to "1" if you'd rather not have
# the dashboard ping github.com hourly.
#
# DEVLOG_VERSION_CHECK_DISABLED=1
