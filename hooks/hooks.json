{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/ensure-server.sh\"", "timeout": 15 },
          { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:7777/api/inject?plugin=1\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/ensure-server.sh\"", "timeout": 15 },
          { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:7777/api/inject?plugin=1\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/pre-release-hook.sh\"", "timeout": 15 }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/pre-standards.sh\"", "timeout": 15 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash|Agent|EnterPlanMode|ExitPlanMode",
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/parse-tags.sh\"", "timeout": 15 }
        ]
      }
    ],
    "SubagentStart": [
      { "hooks": [ { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 } ] }
    ],
    "TaskCreated": [
      { "hooks": [ { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 } ] }
    ],
    "TaskCompleted": [
      { "hooks": [ { "type": "http", "url": "http://127.0.0.1:7777/api/hook", "timeout": 10 } ] }
    ]
  }
}
