{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/ensure-server.sh\" --plugin", "timeout": 20 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/ensure-server.sh\" --plugin", "timeout": 20 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/pre-release-hook.sh\"", "timeout": 15 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/pre-install-hook.sh\"", "timeout": 25 }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/pre-standards.sh\"", "timeout": 15 }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/inject?plugin=1\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash|PowerShell|Agent|EnterPlanMode|ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/parse-tags.sh\"", "timeout": 30 }
        ]
      }
    ],
    "SubagentStart": [
      { "hooks": [ { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 } ] }
    ],
    "TaskCreated": [
      { "hooks": [ { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 } ] }
    ],
    "TaskCompleted": [
      { "hooks": [ { "type": "command", "command": "curl -s -X POST \"http://127.0.0.1:${DEVLOG_PORT:-7777}/api/hook\" -H \"Content-Type: application/json\" --data-binary @-", "timeout": 10 } ] }
    ]
  }
}
